  I:Integer;
  Index:Integer;
Begin
  If Not (tgoAutoFit In Options) Then
  Begin
    Result:=MaxInt;
    Exit;
  End;  
  Result:=0;
  Index:=Column.Index+1;
  If Index=FColumns.Count Then
  Begin
    Result:=MaxInt;
    Exit;
  End;
  For I:=Index To FColumns.Count-1 Do
  Begin
    Column:=FColumns[I];
