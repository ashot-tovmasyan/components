  For I:=0 To Columns.Count-1 Do
  Begin
    AColumn:=Columns[I];
    If AColumn.CreateIndex>Index Then
      Dec(AColumn.FCreateIndex);
  End;
  ColumnBeforeHide(Column);
End;

{---------------------------------------------------------}

Procedure TDCCustomTreeGrid.ColumnBeforeHide(Column:TDCTreeColumn);
