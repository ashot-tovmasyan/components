  If FVisibleColumnCount=0 Then
    CurrentColumn:=Column;
  RecalcTreeColumnIndex;
  If Column.Visible Then
    Inc(FVisibleColumnCount);
  If HandleAllocated Then
    DoAutoFit(ClientWidth,Nil);
End;

