  //Calc new current column
  If CurrentColumn=Column Then
  Begin
    AColumn:=Column.GetNext;
    If AColumn=Nil Then
      FCurrentColumn:=Column.GetPrev
    Else
      FCurrentColumn:=AColumn;
  End;
End;

