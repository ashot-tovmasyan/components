        <GenDll>true</GenDll>
        <DCC_S>false</DCC_S>
        <DCC_UNIT_PLATFORM>false</DCC_UNIT_PLATFORM>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
