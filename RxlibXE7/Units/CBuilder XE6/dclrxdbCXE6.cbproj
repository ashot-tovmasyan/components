        <Cfg_2_Win32>true</Cfg_2_Win32>
        <CfgParent>Cfg_2</CfgParent>
        <Cfg_2>true</Cfg_2>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <SanitizedProjectName>dclrxdbCXE6</SanitizedProjectName>
        <VerInfo_Locale>1049</VerInfo_Locale>
        <VerInfo_Keys>CompanyName=;FileDescription=;FileVersion=1.0.0.0;InternalName=;LegalCopyright=;LegalTrademarks=;OriginalFilename=;ProductName=;ProductVersion=1.0.0.0;Comments=</VerInfo_Keys>
        <DCC_Namespace>Vcl;Vcl.Imaging;Vcl.Touch;Vcl.Samples;Vcl.Shell;System;Xml;Data;Datasnap;Web;Soap;Bde;Winapi;$(DCC_Namespace)</DCC_Namespace>
        <LinkPackageStatics>rtl.lib;vcl.lib;rxctlCXE6.lib;dclrxCXE6.lib;rxdbCXE6.lib;dbrtl.lib;vcldb.lib;bdertl.lib</LinkPackageStatics>
        <_TCHARMapping>wchar_t</_TCHARMapping>
        <IntermediateOutputDir>.\$(Config)\$(Platform)</IntermediateOutputDir>
        <DesignOnlyPackage>true</DesignOnlyPackage>
        <IncludePath>..\;..\..\Units;$(IncludePath)</IncludePath>
        <BCC_PCHCache>true</BCC_PCHCache>
        <ILINK_FullDebugInfo>true</ILINK_FullDebugInfo>
        <DCC_ResourcePath>..\;$(DCC_ResourcePath)</DCC_ResourcePath>
        <DCC_UnitSearchPath>..\;.\;$(BDS)\lib;$(BDS)\lib\obj;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
        <ILINK_AppType>Windows</ILINK_AppType>
        <UsePackages>true</UsePackages>
        <BRCC_IncludePath>..\;$(BDS)\include;$(BDS)\include\vcl;$(BDS)\rx\units;$(BRCC_IncludePath)</BRCC_IncludePath>
        <BRCC_UserSuppliedOptions> -I$(BDS)\include;$(BDS)\include\vcl;$(BDS)\rx\units;$(BDS)\include\dinkumware</BRCC_UserSuppliedOptions>
        <ILINK_GenerateLibFile>true</ILINK_GenerateLibFile>
        <BCC_SourceDebuggingOn>true</BCC_SourceDebuggingOn>
        <DCC_IncludePath>..\;.\;$(BDS)\lib;$(BDS)\lib\obj;$(DCC_IncludePath)</DCC_IncludePath>
        <TASM_IncludePath>$(BDS)\include;$(BDS)\include\vcl;$(BDS)\rx\units;$(TASM_IncludePath)</TASM_IncludePath>
        <ILINK_GenerateImportLibrary>true</ILINK_GenerateImportLibrary>
        <BCC_DisableOptimizations>true</BCC_DisableOptimizations>
        <AllPackageLibs>rtl.lib;vcl.lib;rxctlCXE6.lib;dclrxCXE6.lib;rxdbCXE6.lib;dbrtl.lib;vcldb.lib;bdertl.lib</AllPackageLibs>
        <OutputExt>bpl</OutputExt>
        <ILINK_WinAppType>Package</ILINK_WinAppType>
        <TASM_AdditionalSwitches> /w2</TASM_AdditionalSwitches>
        <ILINK_Description>RX Library Database Components</ILINK_Description>
        <ILINK_ObjectSearchPath>..\;$(ILINK_ObjectSearchPath)</ILINK_ObjectSearchPath>
        <DCC_AdditionalSwitches> -LUdclstd -M</DCC_AdditionalSwitches>
        <DCC_ObjPath>..\;$(DCC_ObjPath)</DCC_ObjPath>
        <DCC_CBuilderOutput>JPHNE</DCC_CBuilderOutput>
        <BCC_DebugLineNumbers>true</BCC_DebugLineNumbers>
        <BCC_InlineFunctionExpansion>false</BCC_InlineFunctionExpansion>
        <ILINK_LibraryPath>..\..\Units;..\;$(BDS)\lib;$(ILINK_LibraryPath)</ILINK_LibraryPath>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base_Win32)'!=''">
        <TASM_Defines>USEPACKAGES;$(TASM_Defines)</TASM_Defines>
        <BRCC_Defines>USEPACKAGES;$(BRCC_Defines)</BRCC_Defines>
        <BCC_UserSuppliedOptions> -Tkh30000 -Vx -r- -k -Ve</BCC_UserSuppliedOptions>
        <DCC_Namespace>System.Win;Data.Win;Datasnap.Win;Web.Win;Soap.Win;Xml.Win;$(DCC_Namespace)</DCC_Namespace>
        <IncludePath>$(BDSINCLUDE)\windows\vcl;$(IncludePath)</IncludePath>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
        <VerInfo_Locale>1033</VerInfo_Locale>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <ILINK_LibraryPath>$(BDS)\lib\debug;$(ILINK_LibraryPath);$(ILINK_LibraryPath)</ILINK_LibraryPath>
        <IntermediateOutputDir>Debug_Build</IntermediateOutputDir>
        <DCC_Define>DEBUG;$(DCC_Define);$(DCC_Define)</DCC_Define>
        <ILINK_DisableIncrementalLinking>true</ILINK_DisableIncrementalLinking>
        <TASM_Debugging>Full</TASM_Debugging>
        <TASM_DisplaySourceLines>true</TASM_DisplaySourceLines>
        <DCC_DebugInfoInExe>true</DCC_DebugInfoInExe>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_1_Win32)'!=''">
        <ILINK_LibraryPath>D:\Documents and Settings\All Users\Documents\RAD Studio\14.0\DCP\;$(BDS)\lib\win32\release\;$(ILINK_LibraryPath)</ILINK_LibraryPath>
        <BCC_Defines>_DEBUG;$(BCC_Defines);$(BCC_Defines)</BCC_Defines>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <IntermediateOutputDir>Release_Build</IntermediateOutputDir>
        <BCC_OptimizeForSpeed>true</BCC_OptimizeForSpeed>
        <TASM_Debugging>None</TASM_Debugging>
        <DCC_AdditionalSwitches> -LUdclstd -M -$O+</DCC_AdditionalSwitches>
        <BCC_InlineFunctionExpansion>true</BCC_InlineFunctionExpansion>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2_Win32)'!=''">
        <BCC_UserSuppliedOptions> -Tkh30000 -Vx -r- -k -Ve -r</BCC_UserSuppliedOptions>
        <BCC_Defines>NDEBUG;$(BCC_Defines);$(BCC_Defines)</BCC_Defines>
    </PropertyGroup>
